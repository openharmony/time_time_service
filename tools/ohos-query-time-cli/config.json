{
  "$schema": "https://schemas.openharmony.org/cli/tool/v1",
  "name": "ohos-query-time",
  "version": "1.0.0",
  "description": "Query system time information including wall time, boot time, monotonic time, and time zone",
  "executable": "/system/bin/cli_tool/executable/ohos-query-time",
  "requirePermissions": [],
  "hasSubcommands": true,
  "subcommands": {
    "get-wall-time": {
      "description": "Get wall time (UTC time in milliseconds from 1970-01-01 00:00:00)",
      "requirePermissions": [],
      "input": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "output": {
        "type": "object",
        "description": "Wall time query result",
        "properties": {
          "time": {
            "type": "string",
            "description": "Wall time in milliseconds"
          },
          "unit": {
            "type": "string",
            "description": "Time unit",
            "enum": ["ms"]
          }
        },
        "required": ["time", "unit"]
      },
      "argumentMapping": {
        "type": "flag",
        "templates": {}
      }
    },
    "get-boot-time": {
      "description": "Get boot time (milliseconds since boot, including sleep time)",
      "requirePermissions": [],
      "input": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "output": {
        "type": "object",
        "description": "Boot time query result",
        "properties": {
          "time": {
            "type": "string",
            "description": "Boot time in milliseconds"
          },
          "unit": {
            "type": "string",
            "description": "Time unit",
            "enum": ["ms"]
          }
        },
        "required": ["time", "unit"]
      },
      "argumentMapping": {
        "type": "flag",
        "templates": {}
      }
    },
    "get-monotonic-time": {
      "description": "Get monotonic time (milliseconds since boot, excluding sleep time)",
      "requirePermissions": [],
      "input": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "output": {
        "type": "object",
        "description": "Monotonic time query result",
        "properties": {
          "time": {
            "type": "string",
            "description": "Monotonic time in milliseconds"
          },
          "unit": {
            "type": "string",
            "description": "Time unit",
            "enum": ["ms"]
          }
        },
        "required": ["time", "unit"]
      },
      "argumentMapping": {
        "type": "flag",
        "templates": {}
      }
    },
    "get-time-zone": {
      "description": "Get current time zone ID",
      "requirePermissions": [],
      "input": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "output": {
        "type": "object",
        "description": "Time zone query result",
        "properties": {
          "timezone": {
            "type": "string",
            "description": "Time zone ID (e.g., Asia/Shanghai)"
          }
        },
        "required": ["timezone"]
      },
      "argumentMapping": {
        "type": "flag",
        "templates": {}
      }
    },
    "--help": {
      "description": "Show help message",
      "requirePermissions": [],
      "input": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "output": {
        "type": "object",
        "description": "Help information"
      },
      "argumentMapping": {
        "type": "flag",
        "templates": {}
      }
    },
    "--version": {
      "description": "Show version information",
      "requirePermissions": [],
      "input": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "output": {
        "type": "object",
        "description": "Version information",
        "properties": {
          "version": {
            "type": "string",
            "description": "Tool version"
          },
          "tool": {
            "type": "string",
            "description": "Tool name"
          }
        },
        "required": ["version", "tool"]
      },
      "argumentMapping": {
        "type": "flag",
        "templates": {}
      }
    }
  },
  "timeout": 30000,
  "events": ["stdout", "stderr", "exit"]
}
